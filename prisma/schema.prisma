generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ KONTRAHENCI (CRM) ============

model Contractor {
  id        String   @id @default(uuid())
  type      String   @default("BUSINESS") // BUSINESS | PERSON
  name      String
  nip       String?  @unique
  phone     String?
  email     String?
  country   String?
  city      String?
  address   String?
  notes     String?
  extras    Json     @default("{}")
  tags      String[] @default([])
  source    String?  // mailing, scraping, manual, referral
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals        Deal[]
  consignments Consignment[]
  emails       Email[]
  invoices     Invoice[]

  @@index([country])
  @@index([tags])
}

// ============ FAKTURY (iFirma) ============

model Invoice {
  id                 String      @id @default(uuid())
  contractorId       String?
  contractor         Contractor? @relation(fields: [contractorId], references: [id])
  ifirmaId           Int?        @unique
  number             String
  issueDate          DateTime
  dueDate            DateTime?
  grossAmount        Float
  currency           String      @default("PLN")
  paidAmount         Float       @default(0)
  status             String      @default("unpaid")
  type               String?
  ifirmaContractorId String?
  extras             Json        @default("{}")
  source             String?   @default("system")
  ifirmaType         String?
  bankReference      String?
  bankDate           DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([contractorId])
  @@index([number])
}

// ============ PIPELINE (STATUSY KLIENTÓW) ============

model Deal {
  id           String   @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  
  status       String   @default("LEAD")
  // LEAD → CONVERSATION → OFFER_SENT → SAMPLES_SENT → INVOICE_SENT → PAID → CLIENT → LOST
  
  language     String?  // fr, de, es, pt, en
  campaign     String?  // "francja surf", "niemcy apteki"
  value        Float?   // wartość deala
  currency     String   @default("EUR")
  notes        String?
  
  nextAction     String?   // "follow up", "send samples", "wait for payment"
  nextActionDate DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities   Activity[]

  @@index([status])
  @@index([campaign])
  @@index([contractorId])
}

model Activity {
  id     String @id @default(uuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id])
  
  type   String // EMAIL_SENT, EMAIL_RECEIVED, NOTE, STATUS_CHANGE, OFFER, SAMPLES, INVOICE, PAYMENT, CALL
  note   String?
  data   Json   @default("{}")
  actor  String @default("system") // user, ai, system, mailing
  
  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([type])
}

// ============ INBOX (MAILE) ============

model Email {
  id           String  @id @default(uuid())
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])
  
  direction    String  // INBOUND | OUTBOUND
  inbox        String  // info, niko, delivery, etc.
  fromEmail    String
  fromName     String?
  toEmail      String
  subject      String?
  bodyPreview  String?
  bodyFull     String?
  messageId    String? @unique
  inReplyTo    String? // threading
  references   String? // full thread chain
  
  isRead       Boolean @default(false)
  isSpam       Boolean @default(false)
  tags         String[] @default([])

  createdAt    DateTime @default(now())

  attachments  EmailAttachment[]

  @@index([contractorId])
  @@index([inbox])
  @@index([isRead])
  @@index([direction])
}

model EmailAttachment {
  id          String   @id @default(uuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  size        Int
  data        Bytes
  createdAt   DateTime @default(now())

  @@index([emailId])
}

// ============ KOMIS ============

model Consignment {
  id           String   @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  
  status       String   @default("OPEN") // OPEN | SETTLED
  notes        String?
  
  createdAt    DateTime @default(now())
  settledAt    DateTime?
  
  items        ConsignmentItem[]

  @@index([contractorId])
  @@index([status])
}

model ConsignmentItem {
  id             String @id @default(uuid())
  consignmentId  String
  consignment    Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)
  
  name           String
  unitPrice      Float
  qtyReceived    Int    @default(0)
  
  createdAt      DateTime @default(now())
  
  returns        ConsignmentReturn[]

  @@unique([consignmentId, name])
}

model ConsignmentReturn {
  id        String @id @default(uuid())
  itemId    String
  item      ConsignmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  qty       Int
  note      String?
  createdAt DateTime @default(now())

  @@index([itemId])
}

// ============ MAILING ============

model MailingContact {
  id         String  @id @default(uuid())
  email      String
  name       String?
  website    String?
  phone      String?
  region     String?
  country    String?
  campaign   String? // "francja surf"
  
  status     String  @default("PENDING") // PENDING | SENT | REPLIED | BOUNCED | UNSUBSCRIBED | CLIENT
  sentAt     DateTime?
  sentFrom   String?  // info@, niko@, etc.
  sentVariant Int?    // which template variant
  
  source     String?  // apify, scraping, manual
  extras     Json    @default("{}")
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([email, campaign])
  @@index([campaign])
  @@index([status])
  @@index([country])
}

// ============ CONFIG ============

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============ MEMORY (AGENT) ============

model Memory {
  id        String   @id @default(uuid())
  chatId    String?
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([createdAt])
}

// ============ IMAP STATE ============

model ImapState {
  inbox     String   @id
  lastUid   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ============ PRODUKTY ============

model Product {
  id        String   @id @default(uuid())
  ean       String   @unique
  name      String
  brand     String   @default("BELL")
  category  String
  variant   String?
  capacity  String?
  pricePLN  Float    @default(18)
  priceEUR  Float    @default(4.5)
  unit      String   @default("szt")
  active    Boolean  @default(true)
  extras    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ SYSTEM EVENTS ============

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  severity  String   @default("info")
  source    String
  message   String
  data      Json     @default("{}")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@index([resolved])
}

// ============ AGENT CONTEXT ============

model AgentContext {
  id        String   @id @default("default")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

// ============ SENDERS (GlobKurier) ============

model Sender {
  id            String   @id @default(uuid())
  globKurierId  String?  @unique
  name          String
  companyName   String?
  street        String?
  houseNumber   String?
  postCode      String?
  city          String?
  country       String?  @default("PL")
  countryId     Int?
  phone         String?
  email         String?
  isDefault     Boolean  @default(false)
  extras        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
}

// ============ MONTHLY PACKAGES ============

model MonthlyPackage {
  id        String     @id @default(uuid())
  period    String     @unique
  status    String     @default("building")
  metadata  Json       @default("{}")
  sentTo    String?
  sentAt    DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]
}

model Document {
  id            String         @id @default(uuid())
  packageId     String
  package       MonthlyPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type          String
  name          String
  filename      String
  invoiceNumber String?
  mimeType      String         @default("application/pdf")
  data          Bytes
  size          Int
  createdAt     DateTime       @default(now())

  @@index([packageId, type])
  @@unique([packageId, filename])
}

// ============ AUDIT LOG ============

model AuditLog {
  id         String   @id @default(uuid())
  actor      String   // user, ai, system, n8n
  action     String
  entityType String
  entityId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
