generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ KONTRAHENCI (CRM) ============

model Contractor {
  id              String    @id @default(uuid())
  type            String    @default("BUSINESS") // BUSINESS | PERSON
  name            String
  nip             String?   @unique
  phone           String?
  email           String?
  country         String?
  city            String?
  address         String?
  notes           String?
  extras          Json      @default("{}")
  tags            String[]  @default([])
  source          String? // mailing, scraping, manual, referral
  lat             Float?
  lng             Float?
  geocodedAt      DateTime?
  geocodingStatus String? // ok | not_found | error | skipped

  // CRM v2 — Etap 1 normalization (backfilled from extras + flat fields)
  preferredLanguage    String? // ISO-2 (pl, en, de, nl, es, fr, it, pt) — używane przez tracking-notify, mailing
  primaryEmail         String? // wskaźnik "główny" — redundant z ContractorContact ale wygodny w listach
  externalIds          Json     @default("{}") // { ifirmaId, gkReceiverId, contasimpleId, ... }
  aliases              String[] @default([]) // alternatywne nazwy + potoczne ("ACME", "Janusz", "ten od Krakowa")
  linkedEsContractorId String? // cross-ref PL ↔ ES (Canarias) 1:1 enforced app-side (helpers.tryAutoLinkEs + /admin/contractors/:id/link-es). @unique zdjete bo prisma db push wymaga --accept-data-loss nawet bez duplikatow — flagi w start scriptcie nie chcemy. Rename do linkedCnContractorId w commicie #17.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals        Deal[]
  consignments Consignment[]
  emails       Email[]
  invoices     Invoice[]
  transactions Transaction[]
  contacts     ContractorContact[]
  addresses    ContractorAddress[]

  @@index([country])
  @@index([tags])
  @@index([primaryEmail])
  @@index([linkedEsContractorId])
}

// CRM v2 Etap 1.2 — multi-email/phone/whatsapp na kontrahencie.
// Zastepuje pojedyncze Contractor.email/phone (te zostaja jako
// quick-access denorm dla list/grepow).
model ContractorContact {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  type       String // 'email' | 'phone' | 'mobile' | 'fax' | 'whatsapp'
  value      String // znormalizowane (email lowercase; tel z prefiksem +48...)
  label      String? // 'office' | 'sales' | 'accounting' | 'shipping' | 'owner' | 'support' | wolny tekst
  personName String? // "Jan Kowalski"
  isPrimary  Boolean @default(false)
  source     String? // 'ifirma', 'contasimple', 'gk', 'mailing', 'manual', 'backfill', 'extras.locations'
  notes      String?
  extras     Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractorId, type, value])
  @@index([contractorId])
  @@index([type, value])
}

// CRM v2 Etap 1.3 — multi-adresy na kontrahencie (billing / delivery /
// office / warehouse). Zastepuje extras.locations[] (zostaje jako
// legacy podczas migracji).
model ContractorAddress {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  type            String // 'billing' | 'delivery' | 'office' | 'warehouse' | 'other'
  label           String? // "glowny magazyn", "biuro Madryt"
  isPrimary       Boolean   @default(false)
  recipientName   String? // dla GK — kogo wpisac jako odbiorce
  street          String?
  houseNumber     String?
  postalCode      String?
  city            String?
  region          String? // wojewodztwo / provincia / state
  country         String? // ISO-2 preferowane, ale tolerancyjne
  countryName     String? // "Niemcy" / "Germany" — co wpisal user, do display
  fullAddress     String? // znormalizowany jednolinijkowy (do geocode + GK)
  lat             Float?
  lng             Float?
  geocodedAt      DateTime?
  geocodingStatus String? // ok | not_found | error | skipped
  source          String?
  extras          Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractorId])
  @@index([type])
  @@index([city])
  @@index([country])
}

// ============ FAKTURY (iFirma) ============

model Invoice {
  id                 String      @id @default(uuid())
  contractorId       String?
  contractor         Contractor? @relation(fields: [contractorId], references: [id])
  ifirmaId           Int?        @unique
  number             String
  issueDate          DateTime
  dueDate            DateTime?
  grossAmount        Decimal     @db.Decimal(12, 2)
  currency           String      @default("PLN")
  paidAmount         Decimal     @default(0) @db.Decimal(12, 2)
  status             String      @default("unpaid")
  type               String?
  ifirmaContractorId String?
  extras             Json        @default("{}")
  source             String?     @default("system")
  ifirmaType         String?
  bankReference      String?
  bankDate           DateTime?

  // CRM v2 Etap 2.1 — denormalized contractor snapshot.
  // Kontrahent moze zmienic adres/nazwe za rok, FV historyczna ma pokazywac
  // prawde z momentu transakcji. Dodatkowo (contractorCountry, issueDate)
  // index pozwala BI queries (analytics/revenue per kraj per okres) puscic
  // bez joina do Contractor.
  contractorName    String?
  contractorNip     String?
  contractorCountry String? // ISO-2
  contractorCity    String?

  // Jawne powiązanie z wysyłką GlobKurier — ustawiane gdy kuriera zamówiono
  // z guzika przy fakturze (ref=numer FV). Dzięki temu strona Faktur pokazuje
  // status wysyłki BEZ kruchego dopasowania po nazwie odbiorcy.
  shipmentNumber  String?
  shipmentHash    String?
  shipmentCarrier String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems InvoiceLineItem[]

  @@index([contractorId])
  @@index([number])
  @@index([contractorCountry, issueDate])
  @@index([currency, issueDate])
}

// CRM v2 Etap 2.2 — pozycje FV PL (VAT 0/5/8/23). Mirror EsInvoiceLineItem.
// Snapshot kontrahenta + issueDate denormalized zeby analytics BI (top
// produkty per kraj per okres) lecial bez joina do Invoice/Contractor.
// ifirmaLineId opcjonalne — backfill historyczny moze nie znac line-id
// z iFirma (nie zawsze go zwracaja w API listy FV / nie pulled z PDF).
model InvoiceLineItem {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  ean            String?
  name           String
  unit           String  @default("szt")
  qty            Decimal @db.Decimal(12, 3)
  unitPriceNetto Decimal @db.Decimal(12, 2)
  vatRate        String // "23" | "8" | "5" | "0" | "ZW" | "NP"
  vatAmount      Decimal @db.Decimal(12, 2)
  totalNetto     Decimal @db.Decimal(12, 2)
  totalGross     Decimal @db.Decimal(12, 2)
  currency       String  @default("PLN")

  // denormalization for BI without joins
  contractorId      String?
  contractorCountry String?
  issueDate         DateTime
  ifirmaLineId      Int?

  position  Int // kolejnosc na FV (1, 2, 3...)
  extras    Json     @default("{}") // GTU_13, jednostka zrodlowa, raw line, inferred:true
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([productId])
  @@index([ean])
  @@index([contractorId, issueDate])
  @@index([contractorCountry, issueDate])
  @@index([ean, issueDate])
}

// ============ PIPELINE (STATUSY KLIENTÓW) ============

model Deal {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  status String @default("LEAD")
  // LEAD → CONVERSATION → OFFER_SENT → SAMPLES_SENT → INVOICE_SENT → PAID → CLIENT → LOST

  language String? // fr, de, es, pt, en
  campaign String? // "francja surf", "niemcy apteki"
  value    Decimal? @db.Decimal(12, 2) // wartość deala
  currency String   @default("EUR")
  notes    String?

  nextAction     String? // "follow up", "send samples", "wait for payment"
  nextActionDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@index([status])
  @@index([campaign])
  @@index([contractorId])
}

model Activity {
  id     String @id @default(uuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id])

  type  String // EMAIL_SENT, EMAIL_RECEIVED, NOTE, STATUS_CHANGE, OFFER, SAMPLES, INVOICE, PAYMENT, CALL
  note  String?
  data  Json    @default("{}")
  actor String  @default("system") // user, ai, system, mailing

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([type])
}

// ============ INBOX (MAILE) ============

model Email {
  id           String      @id @default(uuid())
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])

  direction   String // INBOUND | OUTBOUND
  inbox       String // info, niko, delivery, etc.
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String?
  bodyPreview String?
  bodyFull    String?
  bodyHtml    String? // sanitized-na-froncie HTML treci (obrazki inline przez cid)
  messageId   String? @unique
  inReplyTo   String? // threading
  references  String? // full thread chain

  isRead Boolean  @default(false)
  isSpam Boolean  @default(false)
  tags   String[] @default([])
  extras Json?

  createdAt DateTime @default(now())

  attachments EmailAttachment[]

  @@index([contractorId])
  @@index([inbox])
  @@index([isRead])
  @@index([direction])
  @@index([fromEmail])
  @@index([createdAt])
}

model EmailAttachment {
  id          String   @id @default(uuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  size        Int
  data        Bytes
  cid         String? // Content-ID dla obrazkow inline (<img src="cid:...">)
  createdAt   DateTime @default(now())

  @@index([emailId])
}

// ============ KOMIS ============

model Consignment {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  status String  @default("OPEN") // OPEN | SETTLED
  notes  String?

  createdAt DateTime  @default(now())
  settledAt DateTime?

  items ConsignmentItem[]

  @@index([contractorId])
  @@index([status])
}

model ConsignmentItem {
  id            String      @id @default(uuid())
  consignmentId String
  consignment   Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)

  name        String
  unitPrice   Decimal @db.Decimal(12, 2)
  qtyReceived Int     @default(0)

  createdAt DateTime @default(now())

  returns ConsignmentReturn[]

  @@unique([consignmentId, name])
}

model ConsignmentReturn {
  id     String          @id @default(uuid())
  itemId String
  item   ConsignmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  qty       Int
  note      String?
  createdAt DateTime @default(now())

  @@index([itemId])
}

// ============ MAILING ============

model MailingContact {
  id       String  @id @default(uuid())
  email    String
  name     String?
  website  String?
  phone    String?
  region   String?
  country  String?
  campaign String? // "francja surf"

  status      String    @default("PENDING") // PENDING | SENT | REPLIED | BOUNCED | UNSUBSCRIBED | CLIENT
  sentAt      DateTime?
  sentFrom    String? // info@, niko@, etc.
  sentVariant Int? // which template variant

  source String? // apify, scraping, manual
  extras Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, campaign])
  @@index([campaign])
  @@index([status])
  @@index([country])
}

// ============ CONFIG ============

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============ MEMORY (AGENT) ============

model Memory {
  id        String   @id @default(uuid())
  chatId    String?
  scope     String?  @default("pl") // 'pl' | 'kanary' — separuje boty na jednej bazie. Domyslnie pl bo historycznie pierwszy bot.
  role      String // user | assistant
  content   String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([chatId, scope, createdAt])
  @@index([createdAt])
}

// ============ IMAP STATE ============

model ImapState {
  inbox     String   @id
  lastUid   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ============ PRODUKTY ============

model Product {
  id        String   @id @default(uuid())
  ean       String   @unique
  name      String
  brand     String   @default("BELL")
  category  String
  variant   String?
  capacity  String?
  pricePLN  Decimal  @default(18) @db.Decimal(12, 2)
  priceEUR  Decimal  @default(4.5) @db.Decimal(12, 2)
  unit      String   @default("szt")
  active    Boolean  @default(true)
  extras    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems InvoiceLineItem[]
}

// ============ SYSTEM EVENTS ============

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  severity  String   @default("info")
  source    String
  message   String
  data      Json     @default("{}")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@index([resolved])
}

// ============ AGENT CONTEXT ============

model AgentContext {
  id        String   @id @default("default")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

// Durable backing store for GlobKurier quotes. The hot path keeps quotes in
// req.app.locals.quoteStore (in-memory, fast), but that is lost on restart and
// not shared across instances — so /glob/order could miss a just-made quote and
// the agent would re-quote instead of ordering. Persisting here lets /glob/order
// resolve the quote (by id or most-recent) regardless. Pruned after 30 min.
model Quote {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ============ SENDERS (GlobKurier) ============

model Sender {
  id           String   @id @default(uuid())
  globKurierId String?  @unique
  name         String
  companyName  String?
  street       String?
  houseNumber  String?
  postCode     String?
  city         String?
  country      String?  @default("PL")
  countryId    Int?
  phone        String?
  email        String?
  isDefault    Boolean  @default(false)
  extras       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
}

// ============ MONTHLY PACKAGES ============

model MonthlyPackage {
  id        String     @id @default(uuid())
  period    String     @unique
  status    String     @default("building")
  metadata  Json       @default("{}")
  sentTo    String?
  sentAt    DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]
}

model Document {
  id            String         @id @default(uuid())
  packageId     String
  package       MonthlyPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type          String
  name          String
  filename      String
  invoiceNumber String?
  mimeType      String         @default("application/pdf")
  data          Bytes
  size          Int
  createdAt     DateTime       @default(now())

  @@unique([packageId, filename])
  @@index([packageId, type])
}

// ============ AUDIT LOG ============

model AuditLog {
  id         String   @id @default(uuid())
  actor      String // user, ai, system, n8n
  action     String
  entityType String
  entityId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// CRM v2 Etap 4 — os czasu zdarzen biznesowych (mail wyslany, FV
// wystawiona, paczka nadana, tracking wyslany). Wszystkie hot paths
// emituja przez src/services/activity-log.js (setImmediate, gating
// per-kategoria env). AuditLog zostaje na admin/security trail (sudo
// mutate, gk-raw, admin api), ActivityEvent dla biznesowej historii.
model ActivityEvent {
  id      String @id @default(uuid())
  type    String // patrz VALID_TYPES w src/services/activity-log.js
  summary String
  source  String // 'ifirma' | 'contasimple' | 'gk' | 'imap' | 'mailing' | 'agent' | 'sudo' | 'webhook' | 'system' | 'backfill'

  contractorId   String?
  emailId        String?
  invoiceId      String?
  esInvoiceId    String?
  transactionId  String?
  shipmentNumber String?
  trackingNumber String?

  actorType String  @default("system") // 'user' | 'agent' | 'system' | 'webhook'
  actorId   String? // n8n chatId, agent name ("logistics"), worker id
  payload   Json    @default("{}") // truncated to 10KB; raw size in payload._meta.originalSize

  tags       String[] @default([])
  searchText String? // denormalized blob: summary + payload.subject + contractorName + numbers, ILIKE search

  createdAt DateTime @default(now())

  @@index([contractorId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([invoiceId])
  @@index([esInvoiceId])
  @@index([transactionId])
  @@index([shipmentNumber])
  @@index([tags])
}

// ============ CONTASIMPLE (ES Canarias — druga księgowość, IGIC) ============
//
// Druga firma na Wyspach Kanaryjskich obsługiwana przez Contasimple
// zamiast iFirmy. Tabele całkowicie odrębne od PL Contractor/Invoice —
// zero migracji istniejących danych, zero ryzyka regresji w iFirma flow.

model EsContractor {
  id              String    @id @default(uuid())
  contasimpleId   Int?      @unique // ID kontrahenta po stronie Contasimple
  type            String    @default("Issuer") // Contasimple entity type
  organization    String? // nazwa firmy
  firstname       String?
  lastname        String?
  name            String // denormalized: organization || firstname+lastname
  nif             String? // CIF/NIF/NIE
  email           String?
  phone           String?
  mobile          String?
  address         String?
  city            String?
  province        String?
  country         String?
  countryId       Int?
  postalCode      String?
  documentCulture String? // es-ES | en-US | ca-ES — language for invoices to this customer
  notes           String?
  owner           String? // 'rogacz' | 'nikodem' — biznes wlasciciel kontrahenta; null = traktowany jak Nikodem (default)
  lat             Float?
  lng             Float?
  geocodedAt      DateTime?
  geocodingStatus String? // ok | not_found | error | skipped
  extras          Json      @default("{}") // customField1/2, latitude, longitude, discountPercentage, bankAccounts, ...

  invoices EsInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nif])
  @@index([postalCode])
  @@index([owner])
}

model EsInvoice {
  id            String        @id @default(uuid())
  contasimpleId Int?          @unique // ID FV po stronie Contasimple
  contractorId  String?
  contractor    EsContractor? @relation(fields: [contractorId], references: [id])

  period             String // np. "2026-2T" (kwartał) — finalizujemy w PR #2 po smoke test
  number             String?
  status             String? // Pending | Incomplete | Payed
  invoiceDate        DateTime
  expirationDate     DateTime?
  totalAmount        Decimal?  @db.Decimal(12, 2)
  totalTaxableAmount Decimal?  @db.Decimal(12, 2)
  totalVatAmount     Decimal?  @db.Decimal(12, 2)
  totalPayedAmount   Decimal?  @default(0) @db.Decimal(12, 2)
  currency           String    @default("EUR")
  uiCulture          String? // es-ES | en-US | ca-ES per FV
  numberingFormatId  Int?
  operationType      String? // Nacional / Comunitaria / Exportacion / ...
  extras             Json      @default("{}") // lines, payments, customer snapshot, raw response
  source             String?   @default("contasimple")

  // CRM v2 Etap 2.1 — denormalized contractor snapshot (mirror Invoice).
  // NIF jako "nip" zeby BI queries mogly join'owac/uniowac PL+ES po jednym
  // polu. Rename do "contractorNif" rozwazymy w v2.x jak BI stanie sie
  // krytyczne.
  contractorName    String?
  contractorNip     String? // NIF/CIF/NIE
  contractorCountry String? // ISO-2
  contractorCity    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems EsInvoiceLineItem[]

  @@index([contractorId])
  @@index([number])
  @@index([period])
  @@index([contractorCountry, invoiceDate])
  @@index([currency, invoiceDate])
}

// CRM v2 Etap 2.2 — pozycje FV ES (IGIC 0/3/7/9.5/15/20). Mirror
// InvoiceLineItem. Inny VAT regime (IGIC vs PL VAT), inny katalog (EsProduct),
// dlatego osobna tabela. Wspolne BI queries beda union'em z dwoch tabel
// po contractorCountry + currency + period.
model EsInvoiceLineItem {
  id          String    @id @default(uuid())
  esInvoiceId String
  esInvoice   EsInvoice @relation(fields: [esInvoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   EsProduct? @relation(fields: [productId], references: [id])

  ean            String?
  name           String
  unit           String  @default("szt")
  qty            Decimal @db.Decimal(12, 3)
  unitPriceNetto Decimal @db.Decimal(12, 2)
  vatRate        String // "0" | "3" | "7" | "9.5" | "15" | "20" | "EX"
  vatAmount      Decimal @db.Decimal(12, 2)
  totalNetto     Decimal @db.Decimal(12, 2)
  totalGross     Decimal @db.Decimal(12, 2)
  currency       String  @default("EUR")

  contractorId      String?
  contractorCountry String?
  invoiceDate       DateTime
  contasimpleLineId Int?

  position  Int
  extras    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([esInvoiceId])
  @@index([productId])
  @@index([ean])
  @@index([contractorId, invoiceDate])
  @@index([contractorCountry, invoiceDate])
  @@index([ean, invoiceDate])
}

// Local product catalog for the Canarias company. Synced from Contasimple
// `Products` (POST /sync-products) so preview/confirm flow can resolve items
// without round-tripping the API on every line. Templates (boxes, collections)
// live here too — they expand via extras.composition[] at preview time.
model EsProduct {
  id            String   @id @default(uuid())
  contasimpleId Int?     @unique // numeric id from Contasimple `Products`; null for local-only templates
  ean           String?  @unique // local SKU (e.g. BOX-STICK-ES, BOX-COLLECTION-ES)
  name          String
  category      String   @default("product") // product | template
  variant       String?
  priceEUR      Decimal  @default(0) @db.Decimal(12, 2) // unit netto (Contasimple unitTaxableAmount)
  unit          String   @default("szt")
  active        Boolean  @default(true)
  extras        Json     @default("{}") // {composition: [{name, contasimpleId, qty}], totalQty, isTemplate, aliases}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lineItems EsInvoiceLineItem[]

  @@index([category])
}

// ============ TRANSACTIONS (Operations Tracker) ============
//
// Glues together a single business deal: order-mail → invoice → shipment →
// delivery → payment. Auto-matched by contractor + amount±1% + date (with
// exponential decay weighting). Synced to Google Sheets with checkboxes
// for at-a-glance status of every active deal.

model Transaction {
  id String @id @default(uuid())

  // contractor anchor — strongest match signal
  contractorId   String?
  contractor     Contractor? @relation(fields: [contractorId], references: [id])
  contractorName String? // denormalized for fast GS sync without join

  // linked records (any can be null when stage hasn't happened yet)
  emailId        String? // order email
  invoiceId      String? // FV in our DB
  invoiceNumber  String? // denormalized
  shipmentHash   String? // GK order hash
  shipmentNumber String? // GK260... human number
  trackingNumber String? // courier tracking number (for delivery polling)
  paymentRef     String? // bank reference / iFirma payment id

  // financials (denormalized for GS)
  amount   Decimal? @db.Decimal(12, 2)
  currency String?

  // deal date — used by matcher; usually invoice.issueDate or shipment.creationDate
  occurredAt DateTime @default(now())

  // 5-stage checkboxes synced with Google Sheets
  hasOrder     Boolean   @default(false) // order email arrived / manually noted
  hasInvoice   Boolean   @default(false)
  hasShipped   Boolean   @default(false) // GK order created
  hasDelivered Boolean   @default(false) // courier delivery confirmation
  hasPayment   Boolean   @default(false)
  deliveredAt  DateTime?
  paidAt       DateTime?

  // contents of the package (for "what to pack today" briefing + GS column)
  itemsSummary String? // short, fits in GS row: "60× stick generic"
  itemsDetails Json? // full list, surfaces as GS cell note (hover)

  // Google Sheets sync state
  sheetRowId    Int? // current row in the spreadsheet (1-based)
  sheetSyncedAt DateTime?

  // free-form notes — user-editable in GS, app preserves
  notes String?

  source      String // 'email' | 'invoice' | 'shipment' | 'manual' | 'bootstrap'
  matchScore  Float? // last matcher confidence 0..1 (for review/debug)
  matchReason String? // human-readable: "contractor + 2 days + 0% Δ"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractorId])
  @@index([occurredAt])
  @@index([invoiceId])
  @@index([shipmentHash])
  @@index([hasShipped, hasDelivered])
}

// Faktury KOSZTOWE pobierane z KSeF (gdzie nasza firma jest nabywcą = Subject2).
// Surowy XML FA(3) zachowany; kilka pól zdenormalizowanych do listy/filtrów.
model KsefCostInvoice {
  id            String    @id @default(uuid())
  ksefNumber    String    @unique // numer KSeF (referencyjny)
  invoiceNumber String? // numer faktury sprzedawcy (z XML)
  issueDate     DateTime?
  sellerName    String?
  sellerNip     String?
  buyerNip      String? // nasz NIP (kontekst)
  netAmount     Decimal?  @db.Decimal(14, 2)
  vatAmount     Decimal?  @db.Decimal(14, 2)
  grossAmount   Decimal?  @db.Decimal(14, 2)
  currency      String?   @default("PLN")
  xml           String? // surowy dokument FA(3)
  raw           Json      @default("{}") // metadane z query + parsed snapshot
  fetchedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@index([sellerNip])
  @@index([issueDate])
  @@index([buyerNip])
}
