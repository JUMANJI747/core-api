generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ KONTRAHENCI (CRM) ============

model Contractor {
  id        String   @id @default(uuid())
  type      String   @default("BUSINESS") // BUSINESS | PERSON
  name      String
  nip       String?  @unique
  phone     String?
  email     String?
  country   String?
  city      String?
  address   String?
  notes     String?
  extras    Json     @default("{}")
  tags      String[] @default([])
  source    String? // mailing, scraping, manual, referral
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals        Deal[]
  consignments Consignment[]
  emails       Email[]
  invoices     Invoice[]
  transactions Transaction[]

  @@index([country])
  @@index([tags])
}

// ============ FAKTURY (iFirma) ============

model Invoice {
  id                 String      @id @default(uuid())
  contractorId       String?
  contractor         Contractor? @relation(fields: [contractorId], references: [id])
  ifirmaId           Int?        @unique
  number             String
  issueDate          DateTime
  dueDate            DateTime?
  grossAmount        Decimal     @db.Decimal(12, 2)
  currency           String      @default("PLN")
  paidAmount         Decimal     @default(0) @db.Decimal(12, 2)
  status             String      @default("unpaid")
  type               String?
  ifirmaContractorId String?
  extras             Json        @default("{}")
  source             String?     @default("system")
  ifirmaType         String?
  bankReference      String?
  bankDate           DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([contractorId])
  @@index([number])
}

// ============ PIPELINE (STATUSY KLIENTÓW) ============

model Deal {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  status String @default("LEAD")
  // LEAD → CONVERSATION → OFFER_SENT → SAMPLES_SENT → INVOICE_SENT → PAID → CLIENT → LOST

  language String? // fr, de, es, pt, en
  campaign String? // "francja surf", "niemcy apteki"
  value    Decimal? @db.Decimal(12, 2) // wartość deala
  currency String   @default("EUR")
  notes    String?

  nextAction     String? // "follow up", "send samples", "wait for payment"
  nextActionDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@index([status])
  @@index([campaign])
  @@index([contractorId])
}

model Activity {
  id     String @id @default(uuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id])

  type  String // EMAIL_SENT, EMAIL_RECEIVED, NOTE, STATUS_CHANGE, OFFER, SAMPLES, INVOICE, PAYMENT, CALL
  note  String?
  data  Json    @default("{}")
  actor String  @default("system") // user, ai, system, mailing

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([type])
}

// ============ INBOX (MAILE) ============

model Email {
  id           String      @id @default(uuid())
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])

  direction   String // INBOUND | OUTBOUND
  inbox       String // info, niko, delivery, etc.
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String?
  bodyPreview String?
  bodyFull    String?
  messageId   String? @unique
  inReplyTo   String? // threading
  references  String? // full thread chain

  isRead Boolean  @default(false)
  isSpam Boolean  @default(false)
  tags   String[] @default([])
  extras Json?

  createdAt DateTime @default(now())

  attachments EmailAttachment[]

  @@index([contractorId])
  @@index([inbox])
  @@index([isRead])
  @@index([direction])
}

model EmailAttachment {
  id          String   @id @default(uuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  size        Int
  data        Bytes
  createdAt   DateTime @default(now())

  @@index([emailId])
}

// ============ KOMIS ============

model Consignment {
  id           String     @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  status String  @default("OPEN") // OPEN | SETTLED
  notes  String?

  createdAt DateTime  @default(now())
  settledAt DateTime?

  items ConsignmentItem[]

  @@index([contractorId])
  @@index([status])
}

model ConsignmentItem {
  id            String      @id @default(uuid())
  consignmentId String
  consignment   Consignment @relation(fields: [consignmentId], references: [id], onDelete: Cascade)

  name        String
  unitPrice   Decimal @db.Decimal(12, 2)
  qtyReceived Int     @default(0)

  createdAt DateTime @default(now())

  returns ConsignmentReturn[]

  @@unique([consignmentId, name])
}

model ConsignmentReturn {
  id     String          @id @default(uuid())
  itemId String
  item   ConsignmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  qty       Int
  note      String?
  createdAt DateTime @default(now())

  @@index([itemId])
}

// ============ MAILING ============

model MailingContact {
  id       String  @id @default(uuid())
  email    String
  name     String?
  website  String?
  phone    String?
  region   String?
  country  String?
  campaign String? // "francja surf"

  status      String    @default("PENDING") // PENDING | SENT | REPLIED | BOUNCED | UNSUBSCRIBED | CLIENT
  sentAt      DateTime?
  sentFrom    String? // info@, niko@, etc.
  sentVariant Int? // which template variant

  source String? // apify, scraping, manual
  extras Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, campaign])
  @@index([campaign])
  @@index([status])
  @@index([country])
}

// ============ CONFIG ============

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============ MEMORY (AGENT) ============

model Memory {
  id        String   @id @default(uuid())
  chatId    String?
  role      String // user | assistant
  content   String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([createdAt])
}

// ============ IMAP STATE ============

model ImapState {
  inbox     String   @id
  lastUid   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ============ PRODUKTY ============

model Product {
  id        String   @id @default(uuid())
  ean       String   @unique
  name      String
  brand     String   @default("BELL")
  category  String
  variant   String?
  capacity  String?
  pricePLN  Decimal  @default(18) @db.Decimal(12, 2)
  priceEUR  Decimal  @default(4.5) @db.Decimal(12, 2)
  unit      String   @default("szt")
  active    Boolean  @default(true)
  extras    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ SYSTEM EVENTS ============

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  severity  String   @default("info")
  source    String
  message   String
  data      Json     @default("{}")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@index([resolved])
}

// ============ AGENT CONTEXT ============

model AgentContext {
  id        String   @id @default("default")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

// ============ SENDERS (GlobKurier) ============

model Sender {
  id           String   @id @default(uuid())
  globKurierId String?  @unique
  name         String
  companyName  String?
  street       String?
  houseNumber  String?
  postCode     String?
  city         String?
  country      String?  @default("PL")
  countryId    Int?
  phone        String?
  email        String?
  isDefault    Boolean  @default(false)
  extras       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
}

// ============ MONTHLY PACKAGES ============

model MonthlyPackage {
  id        String     @id @default(uuid())
  period    String     @unique
  status    String     @default("building")
  metadata  Json       @default("{}")
  sentTo    String?
  sentAt    DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  documents Document[]
}

model Document {
  id            String         @id @default(uuid())
  packageId     String
  package       MonthlyPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type          String
  name          String
  filename      String
  invoiceNumber String?
  mimeType      String         @default("application/pdf")
  data          Bytes
  size          Int
  createdAt     DateTime       @default(now())

  @@unique([packageId, filename])
  @@index([packageId, type])
}

// ============ AUDIT LOG ============

model AuditLog {
  id         String   @id @default(uuid())
  actor      String // user, ai, system, n8n
  action     String
  entityType String
  entityId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============ CONTASIMPLE (ES Canarias — druga księgowość, IGIC) ============
//
// Druga firma na Wyspach Kanaryjskich obsługiwana przez Contasimple
// zamiast iFirmy. Tabele całkowicie odrębne od PL Contractor/Invoice —
// zero migracji istniejących danych, zero ryzyka regresji w iFirma flow.

model EsContractor {
  id              String  @id @default(uuid())
  contasimpleId   Int?    @unique // ID kontrahenta po stronie Contasimple
  type            String  @default("Issuer") // Contasimple entity type
  organization    String? // nazwa firmy
  firstname       String?
  lastname        String?
  name            String // denormalized: organization || firstname+lastname
  nif             String? // CIF/NIF/NIE
  email           String?
  phone           String?
  mobile          String?
  address         String?
  city            String?
  province        String?
  country         String?
  countryId       Int?
  postalCode      String?
  documentCulture String? // es-ES | en-US | ca-ES — language for invoices to this customer
  notes           String?
  extras          Json    @default("{}") // customField1/2, latitude, longitude, discountPercentage, bankAccounts, ...

  invoices EsInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nif])
  @@index([postalCode])
}

model EsInvoice {
  id            String        @id @default(uuid())
  contasimpleId Int?          @unique // ID FV po stronie Contasimple
  contractorId  String?
  contractor    EsContractor? @relation(fields: [contractorId], references: [id])

  period             String // np. "2026-2T" (kwartał) — finalizujemy w PR #2 po smoke test
  number             String?
  status             String? // Pending | Incomplete | Payed
  invoiceDate        DateTime
  expirationDate     DateTime?
  totalAmount        Decimal?  @db.Decimal(12, 2)
  totalTaxableAmount Decimal?  @db.Decimal(12, 2)
  totalVatAmount     Decimal?  @db.Decimal(12, 2)
  totalPayedAmount   Decimal?  @default(0) @db.Decimal(12, 2)
  currency           String    @default("EUR")
  uiCulture          String? // es-ES | en-US | ca-ES per FV
  numberingFormatId  Int?
  operationType      String? // Nacional / Comunitaria / Exportacion / ...
  extras             Json      @default("{}") // lines, payments, customer snapshot, raw response
  source             String?   @default("contasimple")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractorId])
  @@index([number])
  @@index([period])
}

// ============ TRANSACTIONS (Operations Tracker) ============
//
// Glues together a single business deal: order-mail → invoice → shipment →
// delivery → payment. Auto-matched by contractor + amount±1% + date (with
// exponential decay weighting). Synced to Google Sheets with checkboxes
// for at-a-glance status of every active deal.

model Transaction {
  id String @id @default(uuid())

  // contractor anchor — strongest match signal
  contractorId   String?
  contractor     Contractor? @relation(fields: [contractorId], references: [id])
  contractorName String? // denormalized for fast GS sync without join

  // linked records (any can be null when stage hasn't happened yet)
  emailId        String? // order email
  invoiceId      String? // FV in our DB
  invoiceNumber  String? // denormalized
  shipmentHash   String? // GK order hash
  shipmentNumber String? // GK260... human number
  trackingNumber String? // courier tracking number (for delivery polling)
  paymentRef     String? // bank reference / iFirma payment id

  // financials (denormalized for GS)
  amount   Decimal? @db.Decimal(12, 2)
  currency String?

  // deal date — used by matcher; usually invoice.issueDate or shipment.creationDate
  occurredAt DateTime @default(now())

  // 5-stage checkboxes synced with Google Sheets
  hasOrder     Boolean   @default(false) // order email arrived / manually noted
  hasInvoice   Boolean   @default(false)
  hasShipped   Boolean   @default(false) // GK order created
  hasDelivered Boolean   @default(false) // courier delivery confirmation
  hasPayment   Boolean   @default(false)
  deliveredAt  DateTime?
  paidAt       DateTime?

  // contents of the package (for "what to pack today" briefing + GS column)
  itemsSummary String? // short, fits in GS row: "60× stick generic"
  itemsDetails Json? // full list, surfaces as GS cell note (hover)

  // Google Sheets sync state
  sheetRowId    Int? // current row in the spreadsheet (1-based)
  sheetSyncedAt DateTime?

  // free-form notes — user-editable in GS, app preserves
  notes String?

  source      String // 'email' | 'invoice' | 'shipment' | 'manual' | 'bootstrap'
  matchScore  Float? // last matcher confidence 0..1 (for review/debug)
  matchReason String? // human-readable: "contractor + 2 days + 0% Δ"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractorId])
  @@index([occurredAt])
  @@index([invoiceId])
  @@index([shipmentHash])
  @@index([hasShipped, hasDelivered])
}
